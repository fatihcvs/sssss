# AI Influencer Bot Environment Variables

# LLM Keys
OPENAI_API_KEY=your_openai_api_key_here

# Image Generation Keys (e.g., Replicate or local ComfyUI URL)
REPLICATE_API_TOKEN=your_replicate_api_token_here
COMFYUI_API_URL=http://127.0.0.1:8188

# Instagram Credentials (if using instagrapi)
IG_USERNAME=your_instagram_username
IG_PASSWORD=your_instagram_password

# Character Configuration
CHARACTER_NAME=Aylin
CHARACTER_STYLE=A 24 year old Turkish woman, dark brown hair, athletic build, modern fashion
FACE_ID_REFERENCE_IMAGE_URL=https://example.com/aylin_reference_face.jpg
